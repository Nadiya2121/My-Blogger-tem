                    <button id="dlClickBtn" class="btn-primary" style="margin-top:0;" onclick="executeDirectLink()">📺 অ্যাড দেখে আনলক করুন</button>
                </div>

                <div style="font-size:14px; font-weight:bold; color:gray; text-align:center; margin-bottom:15px;">— অথবা —</div>
                
                <div style="width:100%; background:var(--bg); border:2px solid transparent; padding:15px; border-radius:12px; position:relative; overflow:hidden;" class="rgb-border">
                    <h3 style="font-size:15px; color:white; font-weight:bold; margin-bottom:5px;"><i class="fa-solid fa-user-plus text-green-400"></i> উপায় ২: বন্ধুকে শেয়ার (VIP)</h3>
                    <p style="font-size:11px; color:gray; margin-bottom:10px; line-height:1.4;">মাত্র ১ জন বন্ধুকে আপনার লিংক থেকে বটে জয়েন করালেই পাবেন ১ দিনের ফ্রি VIP! (সব মুভি অটো আনলক)</p>
                    <button class="btn-outline" style="border-color:var(--success); color:white; background:var(--success); margin-top:0;" onclick="shareToUnlock()"><i class="fa-brands fa-telegram"></i> শেয়ার করে VIP নিন</button>
                </div>
            </div>
        </div>

        <!-- EMOJI QUIZ MODAL -->
        <div id="quizModal" class="modal-overlay" onclick="if(event.target===this) closeModal('quizModal')">
            <div class="bottom-sheet">
                <div class="sheet-handle"></div>
                <h2 style="font-size:20px; font-weight:800; color:white; margin-bottom:10px;">Guess the Movie!</h2>
                <p style="color:var(--text-muted); font-size:12px; margin-bottom:20px;">What movie do these emojis represent?</p>
                
                <div id="quizEmoji" style="font-size:45px; letter-spacing:5px; margin-bottom:20px; text-align:center; background:var(--bg); padding:15px; border-radius:15px; width:100%;">🕷️👨🕸️</div>
                
                <div id="quizOptions" style="display:grid; grid-template-columns: 1fr 1fr; gap:10px; width:100%;">
                    <!-- Options injected via JS -->
                </div>
            </div>
        </div>

        <div id="vipModal" class="modal-overlay" onclick="if(event.target===this) closeModal('vipModal')">
            <div class="bottom-sheet" style="max-height:85vh; overflow-y:auto;">
                <div class="sheet-handle"></div>
                <h2 style="color:var(--warning); margin-bottom:15px;"><i class="fa-solid fa-crown"></i> Get VIP Access</h2>
                <div style="display:flex; width:100%; gap:10px; margin-bottom:15px;">
                    <button style="flex:1; padding:12px; border-radius:10px; background:#e11471; border:none; color:white; font-weight:bold;" onclick="selectPayment('bkash')">bKash</button>
                    <button style="flex:1; padding:12px; border-radius:10px; background:#f97316; border:none; color:white; font-weight:bold;" onclick="selectPayment('nagad')">Nagad</button>
                </div>
                <div id="payBox" style="display:none; width:100%; background:var(--bg); padding:15px; border-radius:12px;">
                    <div style="margin-bottom:15px;">
                        <label><input type="radio" name="vip_pkg" value="7" data-price="10" checked> 7 Days - 10 BDT</label><br><br>
                        <label><input type="radio" name="vip_pkg" value="30" data-price="30"> 30 Days - 30 BDT</label>
                    </div>
                    <p style="font-size:13px; color:var(--text-muted);">Send money to:</p>
                    <h2 id="payNumberText" style="color:var(--success); margin:10px 0; font-size:24px; text-align:center; letter-spacing:2px;">...</h2>
                    <input type="text" id="trxIdInput" placeholder="Enter TrxID here..." style="width:100%; padding:15px; border-radius:10px; border:1px solid var(--surface-light); background:var(--surface); color:white; margin-bottom:15px; outline:none;">
                    <button class="btn-primary" onclick="submitPayment()">Verify Payment</button>
