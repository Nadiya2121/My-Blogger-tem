        <div id="leaderboardModal" class="modal-overlay" onclick="if(event.target===this) closeModal('leaderboardModal')">
            <div class="bottom-sheet">
                <div class="sheet-handle"></div>
                <h2 style="color:var(--warning);"><i class="fa-solid fa-trophy"></i> Top Referrers</h2>
                <div id="lbList" style="width:100%; max-height:50vh; overflow-y:auto; margin-top:15px;"></div>
            </div>
        </div>
        
        <!-- ENHANCED REQUEST MODAL -->
        <div id="reqModal" class="modal-overlay" onclick="if(event.target===this) closeModal('reqModal')">
            <div class="bottom-sheet" style="height:85vh; padding-bottom: 20px;">
                <div class="sheet-handle"></div>
                <h2 style="font-size:24px; font-weight:800; color:white; margin-bottom:5px;"><i class="fa-solid fa-bullhorn text-red-500"></i> Request Movie</h2>
                <p style="color:var(--text-muted); font-size:12px; margin-bottom:15px; text-align:center;">Type exact movie name. Admins will review and upload it soon!</p>
                <div style="display:flex; width:100%; gap:10px; background:var(--bg); padding:10px; border-radius:15px; border:1px solid var(--primary-glow);">
                    <input type="text" id="reqText" placeholder="Movie Name (e.g., Avatar 2)..." style="flex:1; padding:14px; border-radius:10px; background:transparent; border:none; color:white; outline:none; font-weight:bold; font-size:16px;">
                    <button onclick="sendReq()" style="background:var(--primary); color:white; border:none; border-radius:10px; padding:0 22px; font-size:18px; cursor:pointer; box-shadow:0 0 10px var(--primary-glow);"><i class="fa-solid fa-paper-plane"></i></button>
                </div>
                
                <h3 style="width:100%; margin-top:25px; margin-bottom:10px; font-size:16px; border-bottom:1px solid var(--surface-light); padding-bottom:5px;">🔥 Pending Community Requests</h3>
                <div id="reqList" style="width:100%; overflow-y:auto; flex:1; padding-right:5px;"></div>
            </div>
        </div>

        <script>
            let tg = window.Telegram.WebApp; 
            tg.expand();
            
            const DIRECT_LINKS = {{DIRECT_LINKS}};
            const INIT_DATA = tg.initData || "";
            const BOT_UNAME = "{{BOT_USER}}";
            const BKASH_NO = "{{BKASH_NO}}";
            const NAGAD_NO = "{{NAGAD_NO}}";
            
            let uid = tg.initDataUnsafe?.user?.id || 0;
            let loadedMovies = {}; 
            let isUserVip = false;
            let isAdmin = false; 
            let canQuizPlay = false;
            let currentGenre = 'All'; 
            let currentPage = 1;
            let trendingScrollTimer = null; 
            let currentlyViewingMovie = "";
            let currentRating = 5;

            // Quiz Data
            const quizzes = [
                {q: "🕷️👨🕸️", opts: ["Spider-Man", "Batman", "Ant-Man", "Iron Man"], ans: "Spider-Man"},
                {q: "🚢🧊💑", opts: ["Avatar", "Titanic", "Pirates of Caribbean", "Jaws"], ans: "Titanic"},
                {q: "🦁👑", opts: ["Jungle Book", "Tarzan", "The Lion King", "Madagascar"], ans: "The Lion King"},
                {q: "🦇🤡🦇", opts: ["Joker", "Batman", "Dracula", "Venom"], ans: "Batman"},
                {q: "🦖🦕🚙", opts: ["Godzilla", "Jurassic Park", "Transformers", "King Kong"], ans: "Jurassic Park"}
            ];
            let currentQuiz = {};

            // 🚀 FUNCTION TO HANDLE BOT-BAN PROOF IMAGES
            function getImageUrl(photoId) {
                if (photoId.startsWith('http')) return photoId;
                return '/api/image/' + photoId;
            }

            function switchTab(tabId) {
                document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                document.getElementById(tabId + '-tab').classList.add('active');
                event.currentTarget.classList.add('active');
                if(tabId === 'home') window.scrollTo({ top: 0, behavior: 'smooth' });
                if(tabId === 'search') document.getElementById('searchInput').focus();
            }

            function filterGenre(g) {
                currentGenre = g;
                currentPage = 1;
                document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
                event.currentTarget.classList.add('active');
                document.getElementById('latestTitle').innerText = g === 'All' ? '✨ New Releases' : '✨ ' + g + ' Movies';
                loadMovies(currentPage);
            }

            function openModal(id) { document.getElementById(id).classList.add('show'); }
            function closeModal(id) { document.getElementById(id).classList.remove('show'); }

            function showToast(msg, type = "success") {
                const container = document.getElementById('toastContainer');
                const toast = document.createElement('div');
                toast.className = 'toast';
                let icon = type === 'success' ? '<i class="fa-solid fa-circle-check" style="color:var(--success); font-size:18px;"></i>' : '<i class="fa-solid fa-circle-exclamation" style="color:var(--warning); font-size:18px;"></i>';
                if(type === 'error') {
                    toast.style.borderLeftColor = 'var(--primary)';
                    icon = '<i class="fa-solid fa-triangle-exclamation" style="color:var(--primary); font-size:18px;"></i>';
                }
                toast.innerHTML = `${icon} <span>${msg}</span>`;
                container.appendChild(toast);
                setTimeout(() => { if(toast.parentNode) toast.remove(); }, 3500);
            }

            function formatViews(num) {
                if (num >= 1000000) return (num / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
                if (num >= 1000) return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
                return num.toString();
            }

            async function fetchUserInfo() {
                if(tg.initDataUnsafe?.user) {
                    document.getElementById('uName').innerText = tg.initDataUnsafe.user.first_name;
                    if(tg.initDataUnsafe.user.photo_url) document.getElementById('uPic').src = tg.initDataUnsafe.user.photo_url;
                }
                try {
                    const res = await fetch('/api/user/' + uid);
                    const data = await res.json();
                    isUserVip = data.vip;
                    isAdmin = data.is_admin;
                    canQuizPlay = data.can_quiz;
                    
                    document.getElementById('headerCoinCount').innerText = data.coins;
                    if(isUserVip) {
                        document.getElementById('vipBadge').style.display = 'inline-block';
                        if(data.vip_expiry) {
                            document.getElementById('vipExpiryText').style.display = 'block';
                            document.getElementById('vipExpiryText').innerText = 'Valid till: ' + data.vip_expiry;
                        }
                    }
                    document.getElementById('refCountNum').innerText = data.refer_count;
                    document.getElementById('refLinkText').innerText = `https://t.me/${BOT_UNAME}?start=ref_${uid}`;
                    
                    // Setup Streak Text
                    let streakTextHtml = `Current Streak: ${data.streak} Day(s) 🔥`;
                    if(!data.can_checkin) streakTextHtml += " (Claimed)";
                    document.getElementById('streakText').innerText = streakTextHtml;
                    
                    loadTrending();
                    loadMovies(currentPage);
                } catch(e) {}
            }

            function startTrendingAutoScroll() {
                const slider = document.getElementById('trendingList');
                if(!slider || slider.children.length === 0) return;
                
                clearInterval(trendingScrollTimer);
                trendingScrollTimer = setInterval(() => {
                    let maxScroll = slider.scrollWidth - slider.clientWidth;
                    if (slider.scrollLeft >= maxScroll - 10) {
                        slider.scrollTo({ left: 0, behavior: 'smooth' });
                    } else {
                        slider.scrollBy({ left: 155, behavior: 'smooth' });
                    }
                }, 3000); 
            }
            
            function stopTrendingAutoScroll() {
                clearInterval(trendingScrollTimer);
            }

            async function loadTrending() {
                try {
                    const r = await fetch(`/api/trending?uid=${uid}`);
                    const data = await r.json();
                    if(data.length === 0) return;
                    
                    currentHeroMovie = data[0];
                    loadedMovies[currentHeroMovie._id] = currentHeroMovie;
                    document.getElementById('heroBanner').style.display = 'block';
                    document.getElementById('heroImg').src = getImageUrl(currentHeroMovie.photo_id);
                    document.getElementById('heroTitle').innerText = currentHeroMovie._id;
                    
                    let heroMeta = currentHeroMovie.genres ? currentHeroMovie.genres.join(' • ') : '';
                    let heroLangHtml = '';
                    if(currentHeroMovie.language && currentHeroMovie.language !== 'N/A' && currentHeroMovie.language !== 'Not Specified') {
                        heroLangHtml = `<span style="background: linear-gradient(45deg, var(--primary), #be123c); color: white; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 800; margin-right: 8px; box-shadow: 0 0 10px var(--primary-glow);"><i class="fa-solid fa-language"></i> ${currentHeroMovie.language}</span>`;
                    }
                    document.getElementById('heroGenres').innerHTML = heroLangHtml + heroMeta;

                    const grid = document.getElementById('trendingList');
                    grid.innerHTML = data.slice(1).map(m => {
                        loadedMovies[m._id] = m;
                        let langText = (m.language && m.language !== "N/A" && m.language !== "Not Specified") ? ` ${m.language}` : "";
                        let fullTitle = `${m._id}${langText}`;
                        let fileCount = m.files ? m.files.length : 1;
                        
                        return `<div class="h-card" onclick="openQualitySheet('${m._id.replace(/'/g, "\\'")}')">
                            <div class="img-wrap">
                                <img src="${getImageUrl(m.photo_id)}" loading="lazy">
                                <div class="views-tag"><i class="fa-solid fa-eye"></i> ${formatViews(m.clicks)}</div>
                                <div class="quality-tag" style="background:var(--primary);"><i class="fa-solid fa-fire"></i> HOT</div>
                            </div>
                            <div class="card-title">${fullTitle}</div>
                        </div>`;
                    }).join('');
                    
                    grid.addEventListener('touchstart', stopTrendingAutoScroll, {passive: true});
                    grid.addEventListener('touchend', startTrendingAutoScroll);
                    grid.addEventListener('mouseenter', stopTrendingAutoScroll);
                    grid.addEventListener('mouseleave', startTrendingAutoScroll);
                    
                    startTrendingAutoScroll(); 

                } catch(e) {}
            }

            function playHero() { 
                if(currentHeroMovie) openQualitySheet(currentHeroMovie._id); 
            }

            function renderPagination(totalPages, currentPage) {
                if(totalPages <= 1) return "";
                let html = "";
                if(currentPage > 1) {
                    html += `<button class="page-btn" onclick="loadMovies(${currentPage - 1})"><i class="fa-solid fa-chevron-left"></i> Prev</button>`;
                }
                let startPage = Math.max(1, currentPage - 1);
                let endPage = Math.min(totalPages, currentPage + 1);
                if (startPage > 1) html += `<button class="page-btn" onclick="loadMovies(1)">1</button> ... `;
                for(let i = startPage; i <= endPage; i++) {
                    let active = i === currentPage ? "active" : "";
                    html += `<button class="page-btn ${active}" onclick="loadMovies(${i})">${i}</button>`;
                }
                if (endPage < totalPages) html += ` ... <button class="page-btn" onclick="loadMovies(${totalPages})">${totalPages}</button>`;
                if(currentPage < totalPages) {
                    html += `<button class="page-btn" onclick="loadMovies(${currentPage + 1})">Next <i class="fa-solid fa-chevron-right"></i></button>`;
                }
                return html;
            }

            async function loadMovies(page = 1) {
                currentPage = page;
                const grid = document.getElementById('movieGrid');
                grid.innerHTML = "<p style='color:var(--text-muted); text-align:center; width:100%; grid-column:span 2;'><i class='fa-solid fa-spinner fa-spin'></i> Loading...</p>";

                try {
                    const r = await fetch(`/api/list?page=${page}&uid=${uid}&genre=${currentGenre}`);
                    const data = await r.json();
                    
                    if(data.movies.length===0) {
                        grid.innerHTML = "<p style='color:var(--text-muted); text-align:center; width:100%; grid-column:span 2;'>No movies found in this category.</p>";
                        document.getElementById('paginationBox').innerHTML = "";
                        return;
                    }
                    
                    grid.innerHTML = data.movies.map(m => {
                        loadedMovies[m._id] = m;
                        let langText = (m.language && m.language !== "N/A" && m.language !== "Not Specified") ? ` ${m.language}` : "";
                        let fullTitle = `${m._id}${langText}`;
                        let fileCount = m.files ? m.files.length : 1;

                        return `<div class="h-card" onclick="openQualitySheet('${m._id.replace(/'/g, "\\'")}')">
                            <div class="img-wrap">
                                <img src="${getImageUrl(m.photo_id)}" loading="lazy">
                                <div class="views-tag"><i class="fa-solid fa-eye"></i> ${formatViews(m.clicks)}</div>
                                <div class="quality-tag"><i class="fa-solid fa-list"></i> ${fileCount}</div>
                            </div>
                            <div class="card-title">${fullTitle}</div>
                        </div>`;
                    }).join('');
                    
                    document.getElementById('paginationBox').innerHTML = renderPagination(data.total_pages, currentPage);
                    
                    if(page > 1) {
                        document.getElementById('latestTitle').scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }

                } catch(e) {
                     grid.innerHTML = "<p style='color:var(--primary); text-align:center; width:100%; grid-column:span 2;'>Failed to load movies.</p>";
                }
            }

            let searchTimeout;
            document.getElementById('searchInput').addEventListener('input', (e) => {
                clearTimeout(searchTimeout);
                const q = e.target.value.trim();
                if(q === "") return document.getElementById('searchGrid').innerHTML = "";
                searchTimeout = setTimeout(async () => {
                    const grid = document.getElementById('searchGrid');
                    grid.innerHTML = "<p style='color:var(--text-muted); text-align:center; width:100%; grid-column:span 2;'>Searching...</p>";
                    try {
                        const r = await fetch(`/api/list?page=1&q=${encodeURIComponent(q)}&uid=${uid}&genre=All`);
                        const data = await r.json();
                        if(data.movies.length===0) return grid.innerHTML = "<p style='color:var(--text-muted); text-align:center; width:100%; grid-column:span 2;'>No movies found.</p>";
                        
                        grid.innerHTML = data.movies.map(m => {
                            loadedMovies[m._id] = m;
                            let langText = (m.language && m.language !== "N/A" && m.language !== "Not Specified") ? ` ${m.language}` : "";
                            let fullTitle = `${m._id}${langText}`;
                            let fileCount = m.files ? m.files.length : 1;

                            return `<div class="h-card" onclick="openQualitySheet('${m._id.replace(/'/g, "\\'")}')">
                                <div class="img-wrap">
                                    <img src="${getImageUrl(m.photo_id)}" loading="lazy">
                                    <div class="views-tag"><i class="fa-solid fa-eye"></i> ${formatViews(m.clicks)}</div>
                                    <div class="quality-tag"><i class="fa-solid fa-list"></i> ${fileCount}</div>
                                </div>
                                <div class="card-title">${fullTitle}</div>
                            </div>`;
                        }).join('');
                    } catch(e) {}
                }, 500);
            });

            // --- MOVIE DETAILS / REVIEW SHEET ---
            function switchSheetTab(tab) {
                document.getElementById('tabBtnFiles').classList.remove('active');
                document.getElementById('tabBtnReviews').classList.remove('active');
                document.getElementById('sheetSectionFiles').style.display = 'none';
                document.getElementById('sheetSectionReviews').style.display = 'none';
                
                if(tab === 'files') {
                    document.getElementById('tabBtnFiles').classList.add('active');
                    document.getElementById('sheetSectionFiles').style.display = 'block';
                } else {
                    document.getElementById('tabBtnReviews').classList.add('active');
                    document.getElementById('sheetSectionReviews').style.display = 'block';
                    loadReviews(currentlyViewingMovie);
                }
            }

            function setRating(val) {
                currentRating = val;
                const stars = document.getElementById('starInputBox').children;
                for(let i=0; i<5; i++) {
                    if(i < val) stars[i].style.color = "#facc15";
                    else stars[i].style.color = "#555";
                }
            }

            async function submitReview() {
                const txt = document.getElementById('revTextInput').value.trim();
                const uname = document.getElementById('uName').innerText || "User";
                try {
                    const res = await fetch('/api/review', { 
                        method: 'POST', headers: {'Content-Type': 'application/json'}, 
                        body: JSON.stringify({uid: uid, uname: uname, movie: currentlyViewingMovie, rating: currentRating, text: txt, initData: INIT_DATA})
                    });
                    const data = await res.json();
                    if(data.ok) {
                        showToast("✅ Review submitted!");
                        document.getElementById('revTextInput').value = '';
                        loadReviews(currentlyViewingMovie);
                    }
                } catch(e) {}
            }

            async function loadReviews(movieTitle) {
                const div = document.getElementById('reviewsListDiv');
                div.innerHTML = '<p style="text-align:center; color:gray;">Loading reviews...</p>';
                try {
                    const res = await fetch('/api/reviews?movie=' + encodeURIComponent(movieTitle));
                    const data = await res.json();
                    
                    document.getElementById('revAvg').innerText = data.average;
                    document.getElementById('revCount').innerText = `${data.count} reviews`;
                    
                    let starHtml = '';
                    let fullStars = Math.floor(data.average);
                    for(let i=0; i<5; i++) {
                        if(i < fullStars) starHtml += '<i class="fa-solid fa-star"></i>';
                        else starHtml += '<i class="fa-solid fa-star text-gray-500"></i>';
                    }
                    document.getElementById('revStars').innerHTML = starHtml;

                    if(data.reviews.length === 0) {
                        div.innerHTML = '<p style="text-align:center; color:gray; font-size:13px; margin-top:20px;">No reviews yet. Be the first!</p>';
                        return;
                    }

                    div.innerHTML = data.reviews.map(r => {
                        let rStars = '';
                        for(let i=0; i<5; i++) { rStars += (i < r.rating) ? '<i class="fa-solid fa-star" style="color:#facc15; font-size:10px;"></i>' : '<i class="fa-solid fa-star" style="color:#555; font-size:10px;"></i>'; }
                        
                        let delBtn = isAdmin ? `<button onclick="deleteReview('${r.id}')" style="background:transparent; border:none; color:var(--primary); cursor:pointer;"><i class="fa-solid fa-trash"></i></button>` : '';

                        return `
                        <div class="review-box">
                            <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                                <div style="font-weight:bold; font-size:13px;"><i class="fa-solid fa-user-circle text-gray-400"></i> ${r.uname}</div>
                                <div>${rStars} ${delBtn}</div>
                            </div>
                            <div style="font-size:13px; color:var(--text-muted);">${r.text}</div>
                        </div>`;
                    }).join('');
                } catch(e) {}
            }

            // --- ADDED: SECURITY UPDATE FOR DELETE ---
            async function deleteReview(id) {
                if(!confirm("Delete this review?")) return;
                try {
                    await fetch('/api/review/' + id + '?initData=' + encodeURIComponent(INIT_DATA), { method: 'DELETE' });
                    loadReviews(currentlyViewingMovie);
                } catch(e) {}
            }

            let activeFileId = null; 
            let onAdCompleteCallback = null;
            let adStartTime = 0;
            let isWaitingForAd = false;
            let adFallbackTimer = null;

            function openQualitySheet(title) {
                const movie = loadedMovies[title];
                if(!movie) return;
                
                currentlyViewingMovie = title;
                switchSheetTab('files'); // Default tab

                document.getElementById('sheetMovieTitle').innerText = title;
                let listHtml = movie.files.map(f => {
                    let isFree = f.is_unlocked || isUserVip;
                    let icon = isFree ? '<i class="fa-solid fa-cloud-arrow-down" style="color:var(--success);"></i>' : '<i class="fa-solid fa-lock" style="color:var(--primary);"></i>';
                    
