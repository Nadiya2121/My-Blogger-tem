                alert('Movie Deleted!');
                loadDashboardData();
            }

            // --- EDIT MOVIE LOGIC ---
            function openEditModal(encodedTitle) {
                const title = decodeURIComponent(encodedTitle);
                currentEditingMovie = title;
                const movie = allMovies.find(m => m._id === title);
                if(!movie) return;
                
                document.getElementById('editMovieTitle').value = title;
                
                let fileHtml = '';
