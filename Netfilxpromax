class CheckinModel(BaseModel):
    uid: int
    action: str
    initData: str

@app.post("/api/checkin")
async def handle_checkin(data: CheckinModel):
    if not validate_tg_data(data.initData): return {"ok": False}
    user = await db.users.find_one({"user_id": data.uid})
    if not user: return {"ok": False}
    
    now = datetime.datetime.utcnow()
    yesterday_start = (now - datetime.timedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0)
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)
    
    if data.action == "claim":
        last_checkin = user.get("last_checkin", now - datetime.timedelta(days=2))
        streak = user.get("streak", 0)
        
        if last_checkin >= today_start:
            return {"ok": False, "msg": "Already claimed today!"}
            
        if last_checkin >= yesterday_start: streak += 1
        else: streak = 1
        
        coins_to_give = 10
        if streak == 2: coins_to_give = 15
        elif streak == 3: coins_to_give = 20
        elif streak == 4: coins_to_give = 25
        elif streak == 5: coins_to_give = 30
        elif streak == 6: coins_to_give = 40
        elif streak >= 7: coins_to_give = 50

        update_data = {"$inc": {"coins": coins_to_give}, "$set": {"last_checkin": now, "streak": streak}}
        
        got_vip = False
        if streak % 7 == 0:
            got_vip = True
            current_vip = max(user.get("vip_until", now), now)
            update_data["$set"]["vip_until"] = current_vip + datetime.timedelta(days=1)
            
        await db.users.update_one({"user_id": data.uid}, update_data)
        return {"ok": True, "coins": coins_to_give, "streak": streak, "got_vip": got_vip}
        
    elif data.action == "convert":
        coins = user.get("coins", 0)
        if coins < 50: return {"ok": False, "msg": "Not enough coins! (50 required)"}
        current_vip = max(user.get("vip_until", now), now)
        await db.users.update_one({"user_id": data.uid}, {"$inc": {"coins": -50}, "$set": {"vip_until": current_vip + datetime.timedelta(days=1)}})
        return {"ok": True}

