    else:
        pipeline = [{"$group": {"_id": "$title", "photo_id": {"$first": "$photo_id"}, "genres": {"$first": "$genres"}, "language": {"$first": "$movie_lang"}, "clicks": {"$sum": "$clicks"}, "files": {"$push": {"id": {"$toString": "$_id"}, "quality": {"$ifNull": ["$quality", "Main File"]}}}}}, {"$sort": {"clicks": -1}}, {"$limit": 10}]
