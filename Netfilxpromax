                    const data = await res.json();
                    if(data.ok) {
                        alert("File deleted.");
                        closeEditModal();
                        loadDashboardData();
                    }
                } catch(e) {}
            }
            // ------------------------

            async function loadSettings() {
                const res = await fetch('/api/admin/settings_data');
                const data = await res.json();
                document.getElementById('setBkash').value = data.bkash;
                document.getElementById('setNagad').value = data.nagad;
                document.getElementById('setDelTime').value = data.del_time;
                document.getElementById('setTgLink').value = data.tg_link;
                document.getElementById('set18Link').value = data.link_18;
                document.getElementById('setUnlockTime').value = data.unlock_duration;
                
                document.getElementById('linksContainer').innerHTML = data.links.map(l => `
                    <div class="flex justify-between items-center bg-gray-800 p-3 rounded-lg border border-gray-700">
                        <span class="text-sm truncate mr-4">${l}</span>
                        <button onclick="deleteLink('${encodeURIComponent(l)}')" class="text-red-400 hover:text-red-500"><i class="fa-solid fa-trash"></i></button>
                    </div>
                `).join('');
            }

            async function saveSetting(type) {
                let val = "";
                if(type==='bkash') val = document.getElementById('setBkash').value;
                if(type==='nagad') val = document.getElementById('setNagad').value;
                if(type==='time') val = document.getElementById('setDelTime').value;
                if(type==='tg_link') val = document.getElementById('setTgLink').value;
                if(type==='link_18') val = document.getElementById('set18Link').value;
                if(type==='unlock_time') val = document.getElementById('setUnlockTime').value;
                
                await fetch('/api/admin/update_setting', {
                    method: 'POST', headers:{'Content-Type': 'application/json'},
                    body: JSON.stringify({type: type, value: val})
                });
                alert('Settings Updated!');
            }

            async function addLink() {
                const url = document.getElementById('newLink').value;
                if(!url) return;
                await fetch('/api/admin/links', {
                    method: 'POST', headers:{'Content-Type': 'application/json'},
                    body: JSON.stringify({link: url})
                });
                document.getElementById('newLink').value = '';
                loadSettings();
            }

            async function deleteLink(url) {
                await fetch('/api/admin/links?link=' + url, {method: 'DELETE'});
                loadSettings();
            }

            async function userAction(action) {
                const uid = document.getElementById('ctrlUserId').value;
                if(!uid) return alert("Enter User ID!");
                const res = await fetch('/api/admin/user_action', {
                    method: 'POST', headers:{'Content-Type': 'application/json'},
                    body: JSON.stringify({user_id: parseInt(uid), action: action})
                });
                const data = await res.json();
                alert(data.msg);
                document.getElementById('ctrlUserId').value = '';
            }

            loadDashboardData();
        </script>
    </body>
    </html>
    """
    return HTMLResponse(content=html_content)

@app.get("/api/admin/data")
async def get_admin_data(auth: bool = Depends(verify_admin)):
    uc = await db.users.count_documents({})
    now = datetime.datetime.utcnow()
    new_users = await db.users.count_documents({"joined_at": {"$gte": datetime.datetime(now.year, now.month, now.day)}})
    pipeline = [{"$group": {"_id": "$title", "clicks": {"$sum": "$clicks"}, "file_count": {"$sum": 1}, "created_at": {"$max": "$created_at"}, "files": {"$push": {"id": {"$toString": "$_id"}, "quality": {"$ifNull": ["$quality", "Main File"]}}}}}, {"$sort": {"created_at": -1}}, {"$limit": 100}]
    movies = await db.movies.aggregate(pipeline).to_list(100)
    return {"total_users": uc, "total_groups": len(movies), "new_users_today": new_users, "movies": movies}

