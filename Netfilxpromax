            .toast { background: var(--surface-light); color: white; padding: 14px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); animation: slideDown 0.3s forwards, fadeOut 0.3s 3s forwards; border-left: 4px solid var(--primary); }
