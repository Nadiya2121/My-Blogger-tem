    if not validate_tg_data(initData): return {"ok": False}
    parsed = dict(urllib.parse.parse_qsl(initData))
    try:
        user_data = json.loads(parsed.get('user', '{}'))
        if user_data.get('id') not in admin_cache: return {"ok": False}
