# --- Helper for TMDB ---
async def fetch_and_send_tmdb_details(m: types.Message, tmdb_id: str, media_type: str, state: FSMContext, user_id: int):
    url = f"https://api.tmdb.org/3/{media_type}/{tmdb_id}?api_key={TMDB_API_KEY}"
    async with aiohttp.ClientSession() as session:
        async with session.get(url) as resp:
            if resp.status == 200:
                res = await resp.json()
                title = res.get("title") or res.get("name")
                
                release_date = res.get("release_date") or res.get("first_air_date") or ""
                year = release_date[:4] if release_date else ""
                if year:
                    title = f"{title} ({year})"
                
                poster_path = res.get("poster_path")
                genres = [g["name"] for g in res.get("genres", [])]
                
                if not poster_path:
                    return await m.answer("⚠️ এই মুভির কোনো পোস্টার নেই! ম্যানুয়াল আপলোড ব্যবহার করুন।")
                
                poster_url = f"https://image.tmdb.org/t/p/w500{poster_path}"
                try:
                    await bot.send_photo(chat_id=user_id, photo=poster_url, caption=f"✅ <b>{title}</b>\nক্যাটাগরি: {', '.join(genres)}")
                    await state.update_data(title=title, photo_id=poster_url, genres=genres)
                    await state.set_state(AdvancedUpload.waiting_for_language)
                    await bot.send_message(user_id, "🗣 <b>এই মুভিটির ভাষা (Language) সিলেক্ট করুন:</b>", reply_markup=get_language_keyboard(), parse_mode="HTML")
                except Exception as e:
                    await bot.send_message(user_id, "⚠️ পোস্টার ডাউনলোড করতে সমস্যা হচ্ছে। ম্যানুয়াল আপলোড ব্যবহার করুন।")
            else:
                await bot.send_message(user_id, "⚠️ TMDB থেকে ডাটা আনতে সমস্যা হয়েছে!")

@dp.message(AdvancedUpload.waiting_for_tmdb_query)
async def process_tmdb_query(m: types.Message, state: FSMContext):
    query = m.text.strip()
    
    # --- ADDED: Support for TMDB / IMDB links ---
    tmdb_match = re.search(r'themoviedb\.org/(movie|tv)/(\d+)', query)
    imdb_match = re.search(r'tt\d+', query)
    
    if tmdb_match:
        media_type = tmdb_match.group(1)
        tmdb_id = tmdb_match.group(2)
        await fetch_and_send_tmdb_details(m, tmdb_id, media_type, state, m.from_user.id)
        return
        
    async with aiohttp.ClientSession() as session:
        if imdb_match:
            imdb_id = imdb_match.group(0)
            url = f"https://api.tmdb.org/3/find/{imdb_id}?api_key={TMDB_API_KEY}&external_source=imdb_id"
            async with session.get(url) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    movie_res = data.get("movie_results", [])
                    tv_res = data.get("tv_results", [])
                    if movie_res:
                        await fetch_and_send_tmdb_details(m, movie_res[0]["id"], "movie", state, m.from_user.id)
                        return
                    elif tv_res:
                        await fetch_and_send_tmdb_details(m, tv_res[0]["id"], "tv", state, m.from_user.id)
                        return
                    else:
                        return await m.answer("⚠️ IMDB আইডি দিয়ে TMDB তে কিছু পাওয়া যায়নি!")
        
        # Normal Text Search
        url = f"https://api.tmdb.org/3/search/multi?api_key={TMDB_API_KEY}&query={urllib.parse.quote(query)}"
        async with session.get(url) as resp:
            if resp.status == 200:
                data = await resp.json()
                results = data.get("results", [])
                if not results: return await m.answer("⚠️ TMDB তে কিছু পাওয়া যায়নি! অন্য নাম বা লিংক দিয়ে ট্রাই করুন।")
                
                builder = InlineKeyboardBuilder()
                for res in results[:5]:
                    title = res.get("title") or res.get("name")
                    if not title: continue
                    year = res.get("release_date", res.get("first_air_date", ""))[:4]
