@dp.message(AdminStates.waiting_for_bcast)
async def execute_broadcast(m: types.Message, state: FSMContext):
    await state.clear()
    msg = await m.answer("⏳ ব্রডকাস্ট শুরু হয়েছে... ദয়া করে অপেক্ষা করুন।")
    kb = [[types.InlineKeyboardButton(text="🎬 ওপেন মুভি অ্যাপ", web_app=types.WebAppInfo(url=APP_URL))]]
    markup = types.InlineKeyboardMarkup(inline_keyboard=kb)
    
    success = 0
    failed = 0
    cursor = db.users.find()
    users = await cursor.to_list(length=None)
    
    async def send_msg(user_id):
        try:
            await m.copy_to(chat_id=user_id, reply_markup=markup)
            return True
        except Exception: 
            return False

    batch_size = 30
    for i in range(0, len(users), batch_size):
        batch = users[i:i+batch_size]
        tasks = [send_msg(u['user_id']) for u in batch]
        results = await asyncio.gather(*tasks)
        success += sum(1 for r in results if r)
        failed += sum(1 for r in results if not r)
        await asyncio.sleep(1) # Rate limit protection

    await msg.edit_text(f"✅ ব্রডকাস্ট সম্পন্ন!\n\nসর্বমোট পাঠানো হয়েছে: <b>{success}</b> জনকে।\nব্যর্থ হয়েছে: <b>{failed}</b> জনকে।", parse_mode="HTML")

