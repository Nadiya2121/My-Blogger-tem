<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:js='true' b:responsive='true' b:version='2' expr:dir='data:blog.locale.languageDirection' expr:lang='data:blog.locale.language' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>

<head>
<meta expr:charset='data:blog.encoding'/>
<meta content='width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0' name='viewport'/>
<title><data:blog.pageTitle/></title>
<b:include data='blog' name='all-head-content'/>

<b:skin><![CDATA[
/*--- BD MOVIE ZONE - DYNAMIC BADGE & GENRE FIX ---*/
:root {
    --bg-color: #05060a;
    --card-bg: #111217;
    --text-color: #f1f5f9;
    --accent-color: #38bdf8;
    --rating-color: #facc15;
    --border-color: #222;
}

body { background-color: var(--bg-color); color: var(--text-color); margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
a { text-decoration: none; color: inherit; }

/* Header & Search */
.header { background: #111217; padding: 12px 15px; border-bottom: 1px solid var(--border-color); position: sticky; top: 0; z-index: 1000; box-shadow: 0 4px 15px rgba(0,0,0,0.5); }
.header-main { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.logo a { font-size: 22px; font-weight: 900; color: var(--accent-color); text-transform: uppercase; letter-spacing: 1px; }

.search-bar { display: flex; background: #000; border: 1px solid #333; border-radius: 4px; overflow: hidden; max-width: 300px; width: 100%; }
.search-bar input { background: transparent; border: none; padding: 8px 12px; color: #fff; width: 100%; outline: none; font-size: 13px; }
.search-bar button { background: var(--accent-color); border: none; padding: 0 12px; cursor: pointer; }

/* Genre Navigation */
.filter-nav { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 5px; scrollbar-width: none; }
.filter-nav::-webkit-scrollbar { display: none; }
.f-btn { background: #1e293b; padding: 6px 15px; border-radius: 20px; font-size: 11px; font-weight: bold; white-space: nowrap; cursor: pointer; transition: 0.3s; color: #94a3b8; text-transform: uppercase; border: 1px solid transparent; }
.f-btn.active { background: var(--accent-color); color: #000; border-color: var(--accent-color); }

.main-wrapper { max-width: 1240px; margin: 15px auto; padding: 0 10px; }
.section-head { margin-bottom: 15px; padding: 10px; border-left: 4px solid var(--accent-color); background: #111217; font-weight: bold; display: flex; justify-content: space-between; align-items: center; border-radius: 0 4px 4px 0; }

/* Movie Grid */
.movie-grid { display: grid; grid-template-columns: repeat(6, 1fr); grid-gap: 12px; min-height: 400px; }
@media (max-width: 1024px) { .movie-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 600px) { .movie-grid { grid-template-columns: repeat(2, 1fr); } }

.movie-card { background: var(--card-bg); border-radius: 8px; overflow: hidden; border: 1px solid var(--border-color); transition: 0.3s; position: relative; display: flex; flex-direction: column; }
.movie-card:hover { border-color: var(--accent-color); transform: translateY(-5px); box-shadow: 0 5px 15px rgba(56, 189, 248, 0.2); }

.poster-box { aspect-ratio: 2/3; overflow: hidden; position: relative; background: #000; }
.poster-box img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
.movie-card:hover .poster-box img { transform: scale(1.1); }

/* Card Badges */
.card-badge { position: absolute; top: 8px; left: 8px; background: var(--accent-color); color: #000; font-size: 9px; font-weight: 900; padding: 3px 8px; border-radius: 3px; z-index: 2; text-transform: uppercase; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }
.card-rating { position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,0.8); color: var(--rating-color); font-size: 10px; font-weight: 800; padding: 3px 8px; border-radius: 3px; z-index: 2; border: 1px solid var(--rating-color); }

.movie-info { padding: 10px 8px; text-align: center; background: #111217; flex-grow: 1; }
.m-title { font-size: 12px; font-weight: 600; height: 34px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; margin-bottom: 5px; color: #f1f5f9; line-height: 1.4; }
.m-meta { font-size: 10px; color: #64748b; font-weight: bold; text-transform: uppercase; }

/* Pagination */
.pagination { display: flex; flex-direction: column; align-items: center; gap: 10px; margin: 40px 0; }
.nav-btn { background: var(--accent-color); border: none; padding: 10px 25px; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 12px; text-transform: uppercase; transition: 0.3s; }
.nav-btn:hover:not(:disabled) { background: #fff; }
.nav-btn:disabled { opacity: 0.2; cursor: not-allowed; }

#loader { text-align: center; padding: 30px; font-weight: bold; color: var(--accent-color); display: none; }
]]></b:skin>
</head>

<body>

<div class='header'>
    <div class='header-main'>
        <div class='logo'><a expr:href='data:blog.homepageUrl'>BD MOVIE ZONE</a></div>
        <div class='search-bar'>
            <input id='qInput' placeholder='Search movies...' type='text'/>
            <button onclick='doSearch()'><i class='fa fa-search'/></button>
        </div>
    </div>
    <!-- ফিল্টার বাটন (এগুলো আপনার ব্লগের Labels এর সাথে মিল থাকতে হবে) -->
    <div class='filter-nav' id='genreMenu'>
        <div class='f-btn active' onclick='filterBy("", this)'>ALL</div>
        <div class='f-btn' onclick='filterBy("Hindi", this)'>HINDI</div>
        <div class='f-btn' onclick='filterBy("English", this)'>ENGLISH</div>
        <div class='f-btn' onclick='filterBy("Bengali", this)'>BENGALI</div>
        <div class='f-btn' onclick='filterBy("Action", this)'>ACTION</div>
        <div class='f-btn' onclick='filterBy("Comedy", this)'>COMEDY</div>
        <div class='f-btn' onclick='filterBy("Dual Audio", this)'>DUAL AUDIO</div>
    </div>
</div>

<div class='main-wrapper'>
<b:section id='main' name='Main Content'>
  <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='1'>
    <b:includable id='main' var='top'>
      
      <b:if cond='data:view.isMultipleItems'>
        <div class='section-head'>
            <span id='grid-title'>Latest Uploads</span>
            <span id='total-stat' style='font-size:10px; opacity:0.6;'/>
        </div>

        <div id='movie-grid' class='movie-grid'/>
        <div id='loader'>LOADING MOVIES...</div>

        <div class='pagination'>
            <div id='page-info' style='font-size:12px; font-weight:bold; color:#64748b; margin-bottom:5px;'/>
            <div style='display:flex; gap:15px;'>
                <button class='nav-btn' id='prevB' onclick='changePage(-1)'>BACK</button>
                <button class='nav-btn' id='nextB' onclick='changePage(1)'>NEXT</button>
            </div>
        </div>

        <script>//<![CDATA[
          var perPage = 12;
          var currentPage = 1;
          var totalPosts = 0;
          var label = "";
          var query = "";

          function init() {
            var metaUrl = "/feeds/posts/default" + (label ? "/-/" + label : "") + "?alt=json&max-results=0&q=" + query;
            fetch(metaUrl).then(r => r.json()).then(d => {
                totalPosts = parseInt(d.feed.openSearch$totalResults.$t);
                document.getElementById('total-stat').innerText = "Total: " + totalPosts;
                load();
            });
          }

          function load() {
            var grid = document.getElementById('movie-grid');
            var loader = document.getElementById('loader');
            var start = ((currentPage - 1) * perPage) + 1;
            loader.style.display = 'block';
            grid.style.opacity = '0.3';

            fetch("/feeds/posts/default" + (label ? "/-/" + label : "") + "?alt=json&start-index=" + start + "&max-results=" + perPage + "&q=" + query)
              .then(r => r.json()).then(d => {
                grid.innerHTML = "";
                if(d.feed.entry) {
                    d.feed.entry.forEach(post => {
                        var title = post.title.$t;
                        var link = post.link.find(l => l.rel === 'alternate').href;
                        var content = post.content.$t;

                        var temp = document.createElement('div');
                        temp.innerHTML = content;

                        // ১. হাই-কোয়ালিটি ইমেজ
                        var img = "https://via.placeholder.com/300x450?text=No+Poster";
                        var firstImg = temp.querySelector('img');
                        if(firstImg) img = firstImg.src.replace('/w500/', '/original/');

                        // ২. ডাটা এক্সট্রাকশন
                        var rating = "N/A";
                        var lang = "Unknown";
                        var year = "";

                        var infoDivs = temp.querySelectorAll('.info-text div');
                        infoDivs.forEach(div => {
                            var text = div.innerText;
                            if(text.includes('Rating:')) rating = text.split('Rating:')[1].trim().split('/')[0];
                            if(text.includes('Language:')) lang = text.split('Language:')[1].trim();
                            if(text.includes('Release:')) year = text.split('Release:')[1].trim();
                        });

                        // ৩. ডায়নামিক ব্যাজ (ল্যাংগুয়েজ এর প্রথম শব্দ ব্যাজ হিসেবে যাবে)
                        // যেমন: "Hindi English" থাকলে "Hindi" দেখাবে।
                        var posterBadge = lang.split(' ')[0];
                        if(posterBadge === "Unknown") {
                            var badgeEl = temp.querySelector('.badge');
                            posterBadge = badgeEl ? badgeEl.innerText : "HD";
                        }

                        grid.innerHTML += `
                          <div class="movie-card">
                            <a href="${link}">
                                <div class="poster-box">
                                    <div class="card-badge">${posterBadge}</div>
                                    <div class="card-rating">⭐ ${rating}</div>
                                    <img src="${img}" alt="${title}"/>
                                </div>
                                <div class="movie-info">
                                    <div class="m-title">${title}</div>
                                    <div class="m-meta">${lang} ${year ? '('+year+')' : ''}</div>
                                </div>
                            </a>
                          </div>`;
                    });
                }
                updateUI();
                loader.style.display = 'none';
                grid.style.opacity = '1';
                window.scrollTo({top:0, behavior:'smooth'});
            });
          }

          function updateUI() {
            var totalP = Math.ceil(totalPosts / perPage);
            document.getElementById('page-info').innerText = "PAGE " + currentPage + " OF " + (totalP || 1);
            document.getElementById('prevB').disabled = (currentPage <= 1);
            document.getElementById('nextB').disabled = (currentPage >= totalP);
          }

          function changePage(d) { currentPage += d; load(); }
          
          function filterBy(l, b) {
            label = l; query = ""; currentPage = 1;
            document.querySelectorAll('.f-btn').forEach(btn => btn.classList.remove('active'));
            b.classList.add('active');
            document.getElementById('grid-title').innerText = l ? l + " Movies" : "Latest Uploads";
            init();
          }

          function doSearch() {
            var val = document.getElementById('qInput').value;
            if(val) { query = val; label = ""; currentPage = 1; init(); }
          }
          window.onload = init;
        //]]></script>
      
      <b:else/>
        <div style='max-width:900px; margin:0 auto;'>
            <b:loop values='data:posts' var='post'>
                <data:post.body/>
            </b:loop>
        </div>
      </b:if>

    </b:includable>
  </b:widget>
</b:section>
</div>

</body>
</html>
