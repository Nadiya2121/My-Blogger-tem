<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:js='true' b:responsive='true' b:version='2' expr:dir='data:blog.locale.languageDirection' expr:lang='data:blog.locale.language' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>

<head>
<meta expr:charset='data:blog.encoding'/>
<meta content='width=device-width,initial-scale=1,maximum-scale=1,user-scalable=0' name='viewport'/>
<title><data:blog.pageTitle/></title>
<b:include data='blog' name='all-head-content'/>

<b:skin><![CDATA[
/*--- BD MOVIE ZONE - THE FINAL MASTER PRO (CLEAN & PREMIUM) ---*/
:root {
    --bg-color: #05060a;
    --card-bg: #111217;
    --text-color: #f1f5f9;
    --accent-red: #cc0000;
    --accent-blue: #38bdf8;
    --border-color: #222;
    --imdb-color: #f5c518;
    --skeleton-bg: linear-gradient(90deg, #111217 25%, #1a1b22 50%, #111217 75%);
}

body { background-color: var(--bg-color); color: var(--text-color); margin: 0; padding: 0; font-family: 'Poppins', 'Inter', sans-serif; scroll-behavior: smooth; overflow-x: hidden; }
a { text-decoration: none; color: inherit; }

/* 🔥 CUSTOM SCROLLBAR 🔥 */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--bg-color); }
::-webkit-scrollbar-thumb { background: linear-gradient(180deg, var(--accent-red), var(--accent-blue)); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--accent-blue); }

/* 🔥 Central Spinner Loader */
#click-loader { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(5,6,10,0.85); display: none; justify-content: center; align-items: center; z-index: 11000; pointer-events: none; }
.spinner { width: 45px; height: 45px; border: 4px solid #222; border-top: 4px solid var(--accent-blue); border-radius: 50%; animation: spin 0.7s linear infinite; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

/* 🔥 GLASSMORPHISM HEADER 🔥 */
.header-top { 
    background: rgba(17, 18, 23, 0.75); 
    backdrop-filter: blur(12px); 
    -webkit-backdrop-filter: blur(12px);
    padding: 12px 15px; border-bottom: 1px solid rgba(255, 255, 255, 0.05); 
    position: sticky; top: 0; z-index: 1000; display: flex; align-items: center; 
    justify-content: space-between; box-shadow: 0 4px 20px rgba(0,0,0,0.8); 
}
.header-side-space { flex: 1; }
.header-right { flex: 1; display: flex; justify-content: flex-end; }

.logo { flex: 2; text-align: center; }
.logo a { 
    font-size: 24px; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; 
    background: linear-gradient(to right, #ff0000, #38bdf8);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    white-space: nowrap; filter: drop-shadow(0 0 8px rgba(56, 189, 248, 0.4)); transition: 0.3s;
}
@media (max-width: 600px) { .logo a { font-size: 18px; letter-spacing: 1px; } }

/* 18+ Switch Style */
.adult-switch-box { display: flex; align-items: center; gap: 6px; background: rgba(0,0,0,0.5); padding: 4px 10px; border-radius: 50px; border: 1px solid #333; }
.adult-txt { font-size: 9px; font-weight: 800; color: #ff4d4d; text-transform: uppercase; }
.switch { position: relative; display: inline-block; width: 34px; height: 18px; }
.switch input { opacity: 0; width: 0; height: 0; }
.slider-toggle { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #333; transition: .4s; border-radius: 34px; }
.slider-toggle:before { position: absolute; content: ""; height: 12px; width: 12px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
input:checked + .slider-toggle { background-color: var(--accent-red); }
input:checked + .slider-toggle:before { transform: translateX(16px); }

/* RGB ANIMATION KEYFRAMES */
@keyframes rgb-btn-glow {
    0% { border-color: #ff0000; box-shadow: 0 0 15px rgba(255, 0, 0, 0.6); }
    25% { border-color: #ff00ff; box-shadow: 0 0 15px rgba(255, 0, 255, 0.6); }
    50% { border-color: #00bfff; box-shadow: 0 0 15px rgba(0, 191, 255, 0.6); }
    75% { border-color: #00ff00; box-shadow: 0 0 15px rgba(0, 255, 0, 0.6); }
    100% { border-color: #ff0000; box-shadow: 0 0 15px rgba(255, 0, 0, 0.6); }
}

/* Category Buttons */
.custom-nav-container { max-width: 1200px; margin: 20px auto; padding: 0 10px; text-align: center; }
.custom-nav-container ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
.custom-nav-container li { display: inline-block; margin: 0; }
.custom-nav-container li a { 
    background: #111217; color: #fff; padding: 8px 18px; border-radius: 30px; 
    font-weight: 800; font-size: 12px; text-transform: uppercase; 
    border: 2px solid #ff0000; animation: rgb-btn-glow 4s linear infinite; 
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: flex; align-items: center; justify-content: center;
}
.custom-nav-container li a:hover { background: #1a1b22; transform: translateY(-3px) scale(1.05); animation: rgb-btn-glow 1.5s linear infinite; }

/* Search */
.search-wrapper { max-width: 800px; margin: 20px auto; padding: 0 15px; }
.search-form { display: flex; background: #111217; border: 1px solid #333; border-radius: 50px; overflow: hidden; height: 42px; transition: 0.3s; box-shadow: inset 0 0 10px rgba(0,0,0,0.5); }
.search-form input { background: transparent; border: none; padding: 0 20px; color: #fff; width: 100%; outline: none; font-size: 14px; }
.search-form button { background: transparent; border: none; padding: 0 20px; cursor: pointer; color: var(--accent-blue); font-size: 18px; transition: 0.3s; }
.search-form button:hover { color: var(--accent-red); transform: scale(1.1); }

/* Slider */
.slider-container { max-width: 1000px; margin: 10px auto; position: relative; overflow: hidden; border-radius: 12px; border: 1.5px solid #ff0000; animation: rgb-btn-glow 6s linear infinite; }
.movie-slider { display: flex; transition: transform 0.8s cubic-bezier(0.65, 0, 0.35, 1); width: 100%; }
.slide-item { min-width: 100%; aspect-ratio: 16/7.5; background: #000; position: relative; }
@media (max-width: 600px) { .slide-item { aspect-ratio: 16/9; } }
.slide-item img { width: 100%; height: 100%; object-fit: cover; }
.slide-content { position: absolute; bottom: 8px; right: 10px; z-index: 5; }
.slide-btn { background: var(--accent-red); color: #fff; padding: 5px 12px; border-radius: 4px; font-weight: bold; font-size: 10px; text-transform: uppercase; box-shadow: 0 0 10px rgba(204,0,0,0.5); }

/* 🔥 TRENDING NOW UPGRADES 🔥 */
@keyframes fire-flicker { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(1.15); } 100% { opacity: 1; transform: scale(1); } }
.trending-section { max-width: 1000px; margin: 25px auto; padding: 0 10px; }
.trending-head { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; font-size: 16px; font-weight: 900; color: #fff; text-transform: uppercase; border-left: 4px solid var(--accent-red); padding-left: 10px; }
.trending-head i { animation: fire-flicker 1s infinite alternate; }

.trending-scroll-container { overflow-x: auto; white-space: nowrap; scrollbar-width: none; -ms-overflow-style: none; padding-bottom: 10px; }
.trending-scroll-container::-webkit-scrollbar { display: none; }
.trending-wrapper { display: flex; gap: 12px; width: max-content; }
.trending-item { width: calc(33vw - 15px); max-width: 180px; flex-shrink: 0; background: var(--card-bg); border-radius: 8px; border: 1px solid #222; overflow: hidden; position: relative; transition: 0.3s; }
.trending-item:hover { animation: rgb-btn-glow 1.5s linear infinite; transform: translateY(-3px); }

.trending-poster { aspect-ratio: 2/3; position: relative; overflow: hidden; }
.trending-poster img { width: 100%; height: 100%; object-fit: cover; transition: 0.4s; }
.trending-item:hover .trending-poster img { transform: scale(1.05); filter: brightness(0.6); }
.trending-title { font-size: 11px; font-weight: 700; padding: 8px 4px; color: #fff; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; background: #16171d; }

/* 🔥 MOVIE GRID STYLE (BIGGER POSTERS) 🔥 */
.movie-grid { display: grid; grid-template-columns: repeat(5, 1fr); grid-gap: 15px; padding: 10px; } /* 5 in a row for PC */
@media (max-width: 1024px) { .movie-grid { grid-template-columns: repeat(4, 1fr); } } /* 4 for Tablets */
@media (max-width: 768px) { .movie-grid { grid-template-columns: repeat(3, 1fr); grid-gap: 12px; } } /* 3 for small tablets */
@media (max-width: 500px) { .movie-grid { grid-template-columns: repeat(2, 1fr); grid-gap: 10px; } } /* 2 in a row for Mobile - BIGGER & CLEARER */

/* 🔥 RGB HOVER ON MOVIE CARDS 🔥 */
.movie-card { background: var(--card-bg); border-radius: 8px; overflow: hidden; border: 2px solid var(--border-color); position: relative; transition: 0.3s; height: 100%; display: flex; flex-direction: column; }
.movie-card:hover { transform: translateY(-5px); animation: rgb-btn-glow 2s linear infinite; z-index: 10; }

.poster-box { aspect-ratio: 2/3; overflow: hidden; background: #000; position: relative; }
.poster-box img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
.movie-card:hover .poster-box img { transform: scale(1.08); filter: brightness(0.5); }

/* Play Button Hover */
.play-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; z-index: 3; opacity: 0; transition: all 0.4s ease; pointer-events: none; }
.play-overlay i { font-size: 45px; color: rgba(255, 255, 255, 0.9); filter: drop-shadow(0 0 15px var(--accent-red)); transform: scale(0.5); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
.movie-card:hover .play-overlay, .trending-item:hover .play-overlay { opacity: 1; }
.movie-card:hover .play-overlay i, .trending-item:hover .play-overlay i { transform: scale(1); }

/* Badges */
.card-badge { position: absolute; top: 6px; left: 6px; background: var(--accent-red); color: #fff; font-size: 9px; font-weight: bold; padding: 3px 6px; border-radius: 4px; z-index: 4; max-width: 70%; white-space: normal; line-height: 1.2; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }
.card-rating { position: absolute; top: 6px; right: 6px; background: rgba(0,0,0,0.8); color: #facc15; font-size: 9px; font-weight: bold; padding: 3px 6px; border-radius: 4px; z-index: 4; border: 1px solid #facc15; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }
.quality-badge { position: absolute; bottom: 6px; right: 6px; background: var(--accent-blue); color: #000; font-size: 9px; font-weight: 900; padding: 3px 6px; border-radius: 4px; z-index: 4; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }

/* Movie Info */
.movie-info { padding: 10px 6px; text-align: center; background: #16171d; flex-grow: 1; }
.m-title { font-size: 12px; font-weight: 700; height: 34px; overflow: hidden; color: #f1f5f9; line-height: 1.4; margin-bottom: 5px; }
.m-meta { display: flex; align-items: center; justify-content: center; gap: 5px; flex-wrap: wrap; }
.year-badge { background: #222; color: #ccc; font-size: 9px; font-weight: bold; padding: 2px 6px; border-radius: 3px; border: 1px solid #444; }
.lang-text { font-size: 10px; color: var(--accent-blue); font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }

/* Skeleton Loading Animation */
.skeleton-card { background: var(--skeleton-bg); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 8px; aspect-ratio: 2/3.5; }
@keyframes loading { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* Footer Labels */
.bottom-labels { background: #0f1015; padding: 40px 15px; border-top: 1px solid #222; margin-top: 50px; }
.bottom-labels h3 { font-size: 18px; font-weight: 800; color: #fff; text-transform: uppercase; margin-bottom: 25px; text-align: center; display: flex; align-items: center; justify-content: center; gap: 10px; }
.label-list ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
.label-list a { background: #1a1b22; color: #ccc; padding: 8px 16px; border-radius: 6px; font-size: 12px; font-weight: 700; border: 1px solid #333; transition: 0.3s; display: inline-flex; align-items: center; gap: 6px; }
.label-list a:hover { background: var(--accent-blue); color: #000; border-color: var(--accent-blue); transform: translateY(-3px); }

/* Professional Footer */
.site-footer { background: #07080b; padding: 30px 15px; text-align: center; border-top: 1px solid #1a1b22; color: #777; font-size: 12px; line-height: 1.6; }
.footer-logo { font-size: 20px; font-weight: 900; background: linear-gradient(to right, #ff0000, #38bdf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 10px; display: inline-block; }
.dmca-text { max-width: 700px; margin: 10px auto 20px; font-size: 11px; }
.footer-links a { color: #aaa; margin: 0 10px; font-weight: 600; transition: 0.3s; text-transform: uppercase; font-size: 11px; }
.footer-links a:hover { color: var(--accent-blue); }

/* Floating Buttons */
#backToTop { position: fixed; bottom: 20px; right: 20px; background: var(--accent-blue); color: #000; width: 45px; height: 45px; border-radius: 50%; border: none; display: none; z-index: 1000; cursor: pointer; box-shadow: 0 4px 15px rgba(56, 189, 248, 0.4); }
.telegram-float { position: fixed; bottom: 75px; right: 20px; background: #0088cc; color: #fff; width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 1000; box-shadow: 0 4px 15px rgba(0, 136, 204, 0.4); transition: 0.3s; }
.telegram-float:hover { transform: scale(1.1); background: #00aaff; }
.request-btn { position: fixed; bottom: 20px; left: 20px; background: var(--accent-red); color: #fff; padding: 10px 20px; border-radius: 50px; font-weight: 800; font-size: 12px; z-index: 1000; box-shadow: 0 4px 15px rgba(204, 0, 0, 0.4); display: flex; align-items: center; gap: 8px; transition: 0.3s; }
.request-btn:hover { background: #ff1a1a; transform: translateY(-2px); }

.pagination { display: flex; flex-direction: column; align-items: center; gap: 15px; margin: 40px 0; }
.p-btn { background: linear-gradient(135deg, #38bdf8, #0ea5e9); color: #000; padding: 12px 35px; border-radius: 6px; font-weight: 900; cursor: pointer; border: none; font-size: 13px; text-transform: uppercase; box-shadow: 0 4px 10px rgba(56, 189, 248, 0.3); transition: 0.3s; }
.p-btn:hover:not(:disabled) { transform: translateY(-3px); box-shadow: 0 6px 15px rgba(56, 189, 248, 0.5); }
.p-btn:disabled { opacity: 0.3; cursor: not-allowed; }
]]></b:skin>
</head>

<body>

<div id='click-loader'><div class='spinner'/></div>

<!-- Header -->
<div class='header-top'>
    <div class='header-side-space'></div>
    <div class='logo'><a expr:href='data:blog.homepageUrl'>BD MOVIE ZONE</a></div>
    <div class='header-right'>
        <div class='adult-switch-box'>
            <span class='adult-txt'>18+</span>
            <label class='switch'>
              <input id='adultToggle' onchange='toggleAdultMode()' type='checkbox'/>
              <span class='slider-toggle'/>
            </label>
        </div>
    </div>
</div>

<input id='label-holder' type='hidden'>
  <b:attr name='value' expr:value='data:view.isLabelSearch ? data:view.search.label : ""'/>
</input>
<input id='search-holder' type='hidden'>
  <b:attr name='value' expr:value='data:view.isSearch ? data:view.search.query : ""'/>
</input>

<!-- Category Navigation -->
<div class='custom-nav-container'>
  <b:section id='top-navigation' name='Top Nav Buttons' showaddelement='yes'/>
</div>

<!-- Search -->
<div class='search-wrapper'>
    <div class='search-form'>
        <input id='searchInput' placeholder='Search movies...' type='text'/>
        <button onclick='doSearch()'><i class='fa fa-search'/></button>
    </div>
</div>

<b:if cond='data:view.isHomepage'>
  <div class='slider-container'>
      <div class='movie-slider' id='movie-slider'/>
  </div>

  <div class='trending-section'>
      <div class='trending-head'><i class='fas fa-fire' style='color:#ffcc00'/> Trending Now</div>
      <div class='trending-scroll-container' id='trending-container'>
          <div class='trending-wrapper' id='trending-now'>
              <!-- Trending Load Here -->
          </div>
      </div>
  </div>
</b:if>

<div class='main-wrapper'>
<b:section id='main-content' name='Main Content'>
  <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='1'>
    <b:includable id='main' var='top'>
      
      <b:if cond='data:view.isMultipleItems'>
        <div id='movie-grid' class='movie-grid'></div>
        <div class='pagination'>
            <div id='page-info' style='color:#666; font-size:13px; font-weight:bold;'/>
            <div style='display:flex; gap:15px;'>
                <button class='p-btn' id='prevB' onclick='changePage(-1)'><i class='fas fa-arrow-left'/> BACK</button>
                <button class='p-btn' id='nextB' onclick='changePage(1)'>NEXT <i class='fas fa-arrow-right'/></button>
            </div>
        </div>

        <script>//<![CDATA[
          // 🔥 Changed perPage to 15 to perfectly fill 5 columns x 3 rows grid
          var perPage = 15, currentPage = 1, totalPosts = 0;

          document.addEventListener('click', function(e) {
            var anchor = e.target.closest('a');
            if (anchor && anchor.href && !anchor.href.includes('#') && anchor.target !== "_blank" && !anchor.href.startsWith('javascript:')) {
                document.getElementById('click-loader').style.display = 'flex';
                setTimeout(() => { document.getElementById('click-loader').style.display = 'none'; }, 5000);
            }
          });
          window.onpageshow = function() { document.getElementById('click-loader').style.display = 'none'; };

          function toggleAdultMode() {
            var isChecked = document.getElementById('adultToggle').checked;
            if(isChecked) { document.body.classList.add('adult-mode-on'); localStorage.setItem('adultMode', 'enabled'); } 
            else { document.body.classList.remove('adult-mode-on'); localStorage.setItem('adultMode', 'disabled'); }
          }

          function checkAdultPreference() {
            var pref = localStorage.getItem('adultMode');
            if(pref === 'enabled') {
                if(document.getElementById('adultToggle')) document.getElementById('adultToggle').checked = true;
                document.body.classList.add('adult-mode-on');
            }
          }

          function init() {
            checkAdultPreference();
            var label = document.getElementById('label-holder').value.trim();
            var query = document.getElementById('search-holder').value.trim();
            if(window.location.pathname === "/" || window.location.pathname === "/index.html") { loadSlider(); loadTrending(); }
            showSkeletons('movie-grid', 15); // Changed to 15 skeletons
            var feedBase = "/feeds/posts/default";
            if(label !== "") { feedBase += "/-/" + encodeURIComponent(label); }
            fetch(feedBase + "?alt=json&max-results=0").then(r => r.json()).then(d => {
                totalPosts = parseInt(d.feed.openSearch$totalResults.$t);
                loadMovies(feedBase, label, query, 'movie-grid', perPage, true);
            });
          }

          function loadSlider() {
            fetch("/feeds/posts/default?alt=json&max-results=6").then(r => r.json()).then(data => {
                var slider = document.getElementById('movie-slider'), html = "";
                data.feed.entry.forEach(post => {
                    var link = post.link.find(l => l.rel === 'alternate').href;
                    var isAdult = false;
                    if(post.category) post.category.forEach(c => { if(c.term === "adult Movie And Series") isAdult = true; });
                    var temp = document.createElement('div'); temp.innerHTML = post.content.$t;
                    var backdrop = "https://via.placeholder.com/1000x400?text=Poster";
                    var imgs = temp.querySelectorAll('img');
                    for (var i = 0; i < imgs.length; i++) {
                        if (imgs[i].src.includes('780') || imgs[i].src.includes('original')) { backdrop = imgs[i].src; break; } 
                        else if (i === 1) { backdrop = imgs[i].src; }
                    }
                    html += `<div class="slide-item ${isAdult ? 'is-adult-post' : ''}"><a href="${link}"><img src="${backdrop}" loading="lazy"/><div class="slide-content"><div class="slide-btn"><i class="fas fa-play"></i> Watch Now</div></div></a></div>`;
                });
                if(slider) slider.innerHTML = html;
                startAutoSlide();
            });
          }

          var slideIdx = 0;
          function startAutoSlide() { setInterval(() => { slideIdx++; if(slideIdx >= 6) slideIdx = 0; var s = document.getElementById('movie-slider'); if(s) s.style.transform = `translateX(-${slideIdx * 100}%)`; }, 5000); }

          function loadTrending() {
            fetch("/feeds/posts/default/-/Trending?alt=json&max-results=10").then(r => r.json()).then(data => {
                var trending = document.getElementById('trending-now'), html = "";
                if(data.feed.entry) {
                    data.feed.entry.forEach((post) => {
                        var t = post.title.$t, link = post.link.find(l => l.rel === 'alternate').href;
                        var isAdult = false;
                        if(post.category) post.category.forEach(c => { if(c.term === "adult Movie And Series") isAdult = true; });
                        var temp = document.createElement('div'); temp.innerHTML = post.content.$t;
                        var img = temp.querySelector('img') ? temp.querySelector('img').src : "";
                        // 🔥 Removed Rank Badge here
                        html += `<div class="trending-item ${isAdult ? 'is-adult-post' : ''}"><a href="${link}"><div class="trending-poster"><img src="${img}" loading="lazy"/><div class="play-overlay"><i class="fas fa-play-circle"></i></div></div><span class="trending-title">${t}</span></a></div>`;
                    });
                    if(trending) { trending.innerHTML = html; startAutoScroll(); }
                }
            });
          }

          function startAutoScroll() {
            var container = document.getElementById('trending-container');
            var isHovered = false;
            container.onmouseenter = () => isHovered = true;
            container.onmouseleave = () => isHovered = false;
            setInterval(() => { if(!isHovered) { container.scrollLeft += 1; if (container.scrollLeft >= (container.scrollWidth - container.clientWidth - 1)) { container.scrollLeft = 0; } } }, 30);
          }

          function showSkeletons(targetId, count) {
            var grid = document.getElementById(targetId);
            var skelHtml = ""; for(var i=0; i<count; i++) { skelHtml += `<div class="skeleton-card"></div>`; }
            grid.innerHTML = skelHtml;
          }

          function loadMovies(feedBase, label, query, gridId, count, isPagination) {
            var grid = document.getElementById(gridId);
            var start = ((currentPage - 1) * perPage) + 1;
            var url = feedBase + "?alt=json&start-index=" + start + "&max-results=" + count;
            if(label === "" && query !== "") { url += "&q=" + encodeURIComponent(query); }
            fetch(url).then(r => r.json()).then(d => {
                grid.innerHTML = "";
                if(d.feed.entry) {
                    d.feed.entry.forEach((post) => {
                        var t = post.title.$t, link = post.link.find(l => l.rel === 'alternate').href;
                        var isAdult = false;
                        if(post.category) post.category.forEach(c => { if(c.term === "adult Movie And Series") isAdult = true; });
                        var temp = document.createElement('div'); temp.innerHTML = post.content.$t;
                        var img = temp.querySelector('img') ? temp.querySelector('img').src : "";
                        var rating = "N/A", lang = "Unknown";
                        var info = temp.querySelectorAll('.info-text div');
                        info.forEach(div => {
                            if(div.innerText.includes('Rating:')) rating = div.innerText.split('Rating:')[1].trim().split('/')[0];
                            if(div.innerText.includes('Language:')) lang = div.innerText.split('Language:')[1].trim();
                        });
                        
                        var yearMatch = t.match(/\b(19\d{2}|20\d{2})\b/);
                        var year = yearMatch ? yearMatch[0] : "";
                        var yearHtml = year !== "" ? `<span class="year-badge">${year}</span>` : "";

                        var qual = ""; 
                        if(t.toLowerCase().includes("4k")) qual = "4K";
                        else if(t.toLowerCase().includes("1080p")) qual = "1080p";
                        else if(t.toLowerCase().includes("720p")) qual = "720p";
                        else if(t.toLowerCase().includes("web-dl") || t.toLowerCase().includes("webdl")) qual = "WEB-DL";
                        else if(t.toLowerCase().includes("hd")) qual = "HD"; 
                        var qualHtml = qual !== "" ? `<div class="quality-badge">${qual}</div>` : "";

                        var card = document.createElement('div');
                        card.className = "movie-card fade-in" + (isAdult ? " is-adult-post" : "");
                        
                        card.innerHTML = `<a href="${link}"><div class="poster-box"><div class="card-badge">${lang}</div><div class="card-rating">⭐ ${rating}</div><img src="${img}" loading="lazy"/><div class="play-overlay"><i class="fas fa-play-circle"></i></div>${qualHtml}</div><div class="movie-info"><div class="m-title">${t}</div><div class="m-meta">${yearHtml} <span class="lang-text">${lang}</span></div></div></a>`;
                        
                        grid.appendChild(card);
                    });
                }
                if(isPagination) {
                    var tp = Math.ceil(totalPosts / perPage);
                    document.getElementById('page-info').innerText = "PAGE " + currentPage + " OF " + (tp || 1);
                    document.getElementById('prevB').disabled = (currentPage <= 1);
                    document.getElementById('nextB').disabled = (currentPage >= tp);
                    window.scrollTo({top:0, behavior:'smooth'});
                }
            });
          }

          function doSearch() { var v = document.getElementById('searchInput').value; if(v) { window.location.href = "/search?q=" + encodeURIComponent(v); } }
          window.onscroll = function() { var b = document.getElementById("backToTop"); if(document.body.scrollTop > 400 || document.documentElement.scrollTop > 400) b.style.display = "block"; else b.style.display = "none"; };
          function scrollToTop() { window.scrollTo({top: 0, behavior: 'smooth'}); }
          function changePage(d) { currentPage += d; init(); }
          window.onload = init;
        //]]></script>
        
        <button id='backToTop' onclick='scrollToTop()'><i class='fa fa-arrow-up'/></button>
        <a class='telegram-float' href='https://t.me/TGLinkBase' target='_blank'><i class='fab fa-telegram-plane'/></a>
        <a class='request-btn' href='https://t.me/+CeR1S247j-AyZDFl' target='_blank'><i class='fas fa-plus-circle'/> Request Movie</a>

      <b:else/>
        <!-- POST VIEW -->
        <b:loop values='data:posts' var='post'>
          <div style='max-width:900px; margin:0 auto; padding:15px; background:#111217; border-radius:12px; border: 1px solid #222;'>
            <data:post.body/>
            <div id='post-labels-hidden' style='display:none;'>
               <b:loop values='data:post.labels' var='label'><data:label.name/>,</b:loop>
            </div>
            <div class='related-movies-box'>
                <div class='related-title'><i class='fas fa-film'/> SIMILAR MOVIES</div>
                <div id='related-grid' class='movie-grid'></div>
            </div>
            <script>//<![CDATA[
              function loadRelated() {
                var lb = document.getElementById('post-labels-hidden'); if(!lb) return;
                var labels = lb.textContent.split(',').filter(l => l.trim() !== "");
                if(labels.length > 0) {
                    var targetLabel = labels[0].trim();
                    fetch("/feeds/posts/default/-/" + encodeURIComponent(targetLabel) + "?alt=json&max-results=7").then(r => r.json()).then(d => {
                        var grid = document.getElementById('related-grid'); grid.innerHTML = "";
                        if(d.feed.entry) {
                            d.feed.entry.forEach(entry => {
                                var link = entry.link.find(l => l.rel === 'alternate').href;
                                if(window.location.href.indexOf(link) === -1) {
                                    var t = entry.title.$t, temp = document.createElement('div'); temp.innerHTML = entry.content.$t;
                                    var img = temp.querySelector('img') ? temp.querySelector('img').src : "";
                                    grid.innerHTML += `<div class="movie-card"><a href="${link}"><div class="poster-box"><img src="${img}" loading="lazy"/><div class="play-overlay"><i class="fas fa-play-circle"></i></div></div><div class="movie-info"><div class="m-title">${t}</div></div></a></div>`;
                                }
                            });
                        }
                    });
                }
              }
              setTimeout(loadRelated, 500);
              checkAdultPreference();
            //]]></script>
          </div>
        </b:loop>
      </b:if>

    </b:includable>
  </b:widget>
</b:section>
</div>

